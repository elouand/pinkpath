generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MODERATOR
  MEMBER
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  pseudo       String?
  password     String
  email        String?       @unique
  profileUrl   String?
  isAdmin      Boolean       @default(false)
  photos            Photo[]
  members           GroupMember[]
  comments          Comment[]
  likes             Like[]
  itineraries       Itinerary[]
  joinRequests      JoinRequest[]
  followers         Follow[]         @relation("Following")
  following         Follow[]         @relation("Follower")
  notifications     Notification[]   @relation("ReceivedNotifications")
  sentNotifications Notification[]   @relation("SentNotifications")
  createdEvents     Event[]
  eventInterests    EventInterest[]
  reports           Report[]
}

model Follow {
  id          Int      @id @default(autoincrement())
  follower    User     @relation("Follower", fields: [followerId], references: [id])
  followerId  Int
  following   User     @relation("Following", fields: [followingId], references: [id])
  followingId Int
  notify      Boolean  @default(false)
  createdAt   DateTime @default(now())
  @@unique([followerId, followingId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("ReceivedNotifications", fields: [userId], references: [id])
  fromId    Int
  from      User     @relation("SentNotifications", fields: [fromId], references: [id])
  type      String
  photoId   Int?
  eventId   Int?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Event {
  id          Int             @id @default(autoincrement())
  title       String?
  description String?
  startAt     DateTime
  notified    Boolean         @default(false)
  createdAt   DateTime        @default(now())
  group       Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId     Int
  itinerary   Itinerary?      @relation(fields: [itineraryId], references: [id])
  itineraryId Int?
  createdBy   User            @relation(fields: [createdById], references: [id])
  createdById Int
  interested  EventInterest[]
}

model EventInterest {
  id      Int   @id @default(autoincrement())
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId Int
  user    User  @relation(fields: [userId], references: [id])
  userId  Int
  @@unique([eventId, userId])
}

model Itinerary {
  id          Int             @id @default(autoincrement())
  name        String
  duration    Int
  distance    Float
  mode        String
  createdAt   DateTime        @default(now())
  author      User            @relation(fields: [authorId], references: [id])
  authorId    Int
  steps       ItineraryStep[]
  sharedPosts Photo[]         @relation("SharedItinerary")
  events      Event[]
}

model ItineraryStep {
  id          Int       @id @default(autoincrement())
  order       Int
  name        String
  type        String?
  latitude    Float
  longitude   Float
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  itineraryId Int
}

model Photo {
  id          Int      @id @default(autoincrement())
  url         String
  audioUrl    String?
  description String?
  type_lieu   String
  latitude    Float
  longitude   Float
  date        DateTime @default(now())
  is_public   Boolean  @default(true)

  // Relations existantes
  author   User?  @relation(fields: [authorId], references: [id])
  authorId Int?
  groupId  Int?
  group    Group? @relation(fields: [groupId], references: [id])

  // Itinéraire partagé (optionnel)
  itineraryId Int?
  itinerary   Itinerary? @relation("SharedItinerary", fields: [itineraryId], references: [id])

  // --- NOUVEAUX CHAMPS ---
  tags       Tag[]
  comments   Comment[]
  likesCount Int       @default(0)
  likedBy    Like[]
  reports    Report[]
}

model Report {
  id         Int      @id @default(autoincrement())
  reporter   User     @relation(fields: [reporterId], references: [id])
  reporterId Int
  photo      Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  photoId    Int
  createdAt  DateTime @default(now())
  @@unique([reporterId, photoId])
}

model Tag {
  id     Int     @id @default(autoincrement())
  name   String  @unique // ex: "randonnée"
  photos Photo[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())

  // L'auteur du commentaire
  author   User @relation(fields: [authorId], references: [id])
  authorId Int

  // La photo concernée
  photo   Photo @relation(fields: [photoId], references: [id])
  photoId Int
}

model Group {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?
  imageUrl     String?
  isPublic     Boolean       @default(true)
  members      GroupMember[]
  photos       Photo[]
  joinRequests JoinRequest[]
  events       Event[]
}

model GroupMember {
  id      Int   @id @default(autoincrement())
  role    Role  @default(MEMBER)
  user    User  @relation(fields: [userId], references: [id])
  userId  Int
  group   Group @relation(fields: [groupId], references: [id])
  groupId Int

  @@unique([userId, groupId])
}

model Like {
  id      Int   @id @default(autoincrement())
  user    User  @relation(fields: [userId], references: [id])
  userId  Int
  photo   Photo @relation(fields: [photoId], references: [id])
  photoId Int

  // ⚠️ CETTE LIGNE EST LA CLÉ :
  // Elle interdit d'avoir deux fois le même couple userId/photoId
  @@unique([userId, photoId])
}

model PointOfInterest {
  id         Int    @id @default(autoincrement())
  name       String
  category   String // restauration, loisirs, culture [cite: 51]
  latitude   Float
  longitude  Float
  budget_est Float
  effort_lvl Int // 1 à 5 (enfants, seniors) [cite: 52]
}

model JoinRequest {
  id        Int      @id @default(autoincrement())
  userId    Int
  groupId   Int
  user      User     @relation(fields: [userId], references: [id])
  group     Group    @relation(fields: [groupId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, groupId])
}
