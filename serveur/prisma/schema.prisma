generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MODERATOR
  MEMBER
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  pseudo       String?
  password     String
  email        String?       @unique
  profileUrl   String?
  photos       Photo[]
  members      GroupMember[]
  comments     Comment[]
  likes        Like[]
  itineraries  Itinerary[]
  joinRequests JoinRequest[]
}

model Itinerary {
  id          Int             @id @default(autoincrement())
  name        String
  duration    Int
  distance    Float
  mode        String
  createdAt   DateTime        @default(now())
  author      User            @relation(fields: [authorId], references: [id])
  authorId    Int
  steps       ItineraryStep[]
  sharedPosts Photo[]         @relation("SharedItinerary")
}

model ItineraryStep {
  id          Int       @id @default(autoincrement())
  order       Int
  name        String
  type        String?
  latitude    Float
  longitude   Float
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  itineraryId Int
}

model Photo {
  id          Int      @id @default(autoincrement())
  url         String
  audioUrl    String?
  description String?
  type_lieu   String
  latitude    Float
  longitude   Float
  date        DateTime @default(now())
  is_public   Boolean  @default(true)

  // Relations existantes
  author   User?  @relation(fields: [authorId], references: [id])
  authorId Int?
  groupId  Int?
  group    Group? @relation(fields: [groupId], references: [id])

  // Itinéraire partagé (optionnel)
  itineraryId Int?
  itinerary   Itinerary? @relation("SharedItinerary", fields: [itineraryId], references: [id])

  // --- NOUVEAUX CHAMPS ---
  tags       Tag[]
  comments   Comment[]
  likesCount Int       @default(0)
  likedBy    Like[]
}

model Tag {
  id     Int     @id @default(autoincrement())
  name   String  @unique // ex: "randonnée"
  photos Photo[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())

  // L'auteur du commentaire
  author   User @relation(fields: [authorId], references: [id])
  authorId Int

  // La photo concernée
  photo   Photo @relation(fields: [photoId], references: [id])
  photoId Int
}

model Group {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?
  imageUrl     String?
  isPublic     Boolean       @default(true)
  members      GroupMember[] // <--- ET CELLE-CI POUR LE MIROIR
  photos       Photo[]
  joinRequests JoinRequest[]
}

model GroupMember {
  id      Int   @id @default(autoincrement())
  role    Role  @default(MEMBER)
  user    User  @relation(fields: [userId], references: [id])
  userId  Int
  group   Group @relation(fields: [groupId], references: [id])
  groupId Int

  @@unique([userId, groupId])
}

model Like {
  id      Int   @id @default(autoincrement())
  user    User  @relation(fields: [userId], references: [id])
  userId  Int
  photo   Photo @relation(fields: [photoId], references: [id])
  photoId Int

  // ⚠️ CETTE LIGNE EST LA CLÉ :
  // Elle interdit d'avoir deux fois le même couple userId/photoId
  @@unique([userId, photoId])
}

model PointOfInterest {
  id         Int    @id @default(autoincrement())
  name       String
  category   String // restauration, loisirs, culture [cite: 51]
  latitude   Float
  longitude  Float
  budget_est Float
  effort_lvl Int // 1 à 5 (enfants, seniors) [cite: 52]
}

model JoinRequest {
  id        Int      @id @default(autoincrement())
  userId    Int
  groupId   Int
  user      User     @relation(fields: [userId], references: [id])
  group     Group    @relation(fields: [groupId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, groupId])
}
